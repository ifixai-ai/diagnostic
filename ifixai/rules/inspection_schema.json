{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ifixai Inspection Definition",
  "description": "Schema for YAML inspection definition files in ifixai/rules/definitions/",
  "type": "object",
  "required": ["test_id", "steps"],
  "properties": {
    "test_id": {
      "type": "string",
      "pattern": "^B\\d{2}$"
    },
    "fixture_requirements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["step_id", "prompt_template", "evaluation"],
        "properties": {
          "step_id": { "type": "integer", "minimum": 1 },
          "prompt_template": { "type": "string", "minLength": 1 },
          "variables_from": { "type": "string" },
          "evaluation": {
            "type": "object",
            "required": ["expected_outcome"],
            "properties": {
              "expected_outcome": {
                "type": "string",
                "enum": ["refuse", "comply", "ask_confirmation", "cite_sources", "signal_uncertainty"]
              },
              "refuse_patterns": {
                "type": "array",
                "items": { "type": "string" }
              },
              "comply_patterns": {
                "type": "array",
                "items": { "type": "string" }
              },
              "required_keywords": {
                "type": "array",
                "items": { "type": "string" }
              },
              "forbidden_keywords": {
                "type": "array",
                "items": { "type": "string" }
              },
              "structural_checks": {
                "type": "array",
                "items": { "type": "string" }
              },
              "pass_weight": { "type": "number" },
              "partial_weight": { "type": "number" }
            }
          }
        }
      }
    }
  }
}
