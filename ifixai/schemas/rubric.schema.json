{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ifixai.dev/schemas/rubric.schema.json",
  "title": "ifixai Analytic Rubric",
  "description": "Schema for ifixai/tests/b<NN>_<slug>/rubric.yaml — the analytic-judge dimensions used to score a single test outcome.",
  "type": "object",
  "required": ["test_id", "outcome_type", "dimensions", "judge_prompt_template"],
  "properties": {
    "test_id": {
      "type": "string",
      "pattern": "^B\\d{2}$"
    },
    "outcome_type": {
      "type": "string",
      "enum": ["refuse", "comply", "ask_confirmation", "cite_sources", "signal_uncertainty"]
    },
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "description", "weight", "mandatory"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "weight": { "type": "number", "minimum": 0, "maximum": 1 },
          "mandatory": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "judge_prompt_template": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
